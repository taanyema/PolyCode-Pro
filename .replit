modules = ["python-3.11"]
run = "python app.py"

[nix]
channel = "stable-23_11"
packages = ["cairo", "ffmpeg-full", "freetype", "ghostscript", "gobject-introspection", "gtk3", "pkg-config", "qhull", "tcl", "tk"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 10000
externalPort = 3000

[agent]
expertMode = true
